<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 气泡主体 -->
    <item>
        <shape>
            <solid android:color="#4CAF50" />
            <corners android:radius="12dp" />
            <padding
                android:left="8dp"
                android:right="8dp"
                android:top="8dp"
                android:bottom="8dp" />
        </shape>
    </item>
    <!-- 右侧箭头 -->
    <item
        android:right="8dp">
        <rotate
            android:fromDegrees="45"
            android:pivotX="0%"
            android:pivotY="100%">
            <shape>
                <solid android:color="#4CAF50" />
                <size
                    android:width="12dp"
                    android:height="12dp" />
            </shape>
        </rotate>
    </item>
</layer-list>